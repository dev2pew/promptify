# ----------------------------------------------------------------
# PROMPTIFY CONFIGURATION
# THIS FILE CONTAINS ONLY USER PREFERENCES AND SAFE LOCAL SETTINGS.
# INVALID VALUES FALL BACK TO CODE DEFAULTS.
# ----------------------------------------------------------------

# ----------------------------------------------------------------
# CORE RUNTIME
# ----------------------------------------------------------------

# MAXIMUM FILE SIZE IN BYTES ALLOWED TO BE READ
PROMPTIFY_MAX_FILE_SIZE=5242880

# MAXIMUM CONCURRENT FILE READS TO PREVENT OS DESCRIPTOR EXHAUSTION
PROMPTIFY_MAX_CONCURRENT_READS=64

# DEFAULT LANGUAGE LOCALE FOR STRINGS
PROMPTIFY_LOCALE="en"

# BASE IGNORE RULES MERGED INTO EVERY PROJECT SCAN
# COMMA-SEPARATED GITIGNORE-STYLE ENTRIES
PROMPTIFY_DEFAULT_IGNORES=".git/,.svn/,__pycache__/,.venv/,node_modules/"

# ----------------------------------------------------------------
# OUTPUT BEHAVIOR
# ----------------------------------------------------------------

# COPY THE FINAL OUTPUT TO THE SYSTEM CLIPBOARD AFTER SAVING
PROMPTIFY_COPY_OUTPUT_TO_CLIPBOARD=true

# SAVE THE RAW INTERACTIVE BUFFER ALONGSIDE THE RESOLVED OUTPUT
PROMPTIFY_SAVE_RAW_OUTPUT=true

# ----------------------------------------------------------------
# LOGGER
# ----------------------------------------------------------------

# 0 = QUIETER, 1 = DEFAULT, 2+ = VERBOSE
PROMPTIFY_LOG_VERBOSITY=1

# INCLUDE [HH:MM:SS] TIMESTAMPS IN CLI OUTPUT
PROMPTIFY_LOG_TIMESTAMPS=false

PROMPTIFY_LOG_PREFIX_NORMAL="[>]"
PROMPTIFY_LOG_PREFIX_ERROR="[e]"
PROMPTIFY_LOG_PREFIX_SUCCESS="[+]"
PROMPTIFY_LOG_PREFIX_WARNING="[w]"
PROMPTIFY_LOG_PREFIX_INFO="[i]"
PROMPTIFY_LOG_PREFIX_NOTICE="[*]"
PROMPTIFY_LOG_PREFIX_VERBOSE="[v]"

# VALID COLORS: ansiblack, ansired, ansigreen, ansiyellow, ansiblue,
# ansimagenta, ansicyan, ansiwhite, ansigray, ansibrightblack,
# ansibrightred, ansibrightgreen, ansibrightyellow, ansibrightblue,
# ansibrightmagenta, ansibrightcyan, ansibrightwhite
PROMPTIFY_LOG_COLOR_NORMAL="ansiblue"
PROMPTIFY_LOG_COLOR_ERROR="ansired"
PROMPTIFY_LOG_COLOR_SUCCESS="ansigreen"
PROMPTIFY_LOG_COLOR_WARNING="ansiyellow"
PROMPTIFY_LOG_COLOR_INFO="ansiblue"
PROMPTIFY_LOG_COLOR_NOTICE="ansimagenta"
PROMPTIFY_LOG_COLOR_VERBOSE="ansigray"

# INTERACTIVE INPUT PROMPT DECORATION
PROMPTIFY_LOG_INPUT_PREFIX="[<]"
PROMPTIFY_LOG_INPUT_PREFIX_COLOR="ansicyan"
PROMPTIFY_LOG_INPUT_SUFFIX=">>"

# ----------------------------------------------------------------
# TERMINAL RENDERING
# ----------------------------------------------------------------

# TERMINAL CAPABILITY PROFILE
# auto = detect from the current terminal/session
# modern = always use unicode borders and glyphs
# legacy-cmd = force ASCII-safe rendering for old cmd.exe or raster fonts
# vscode / windows-terminal = explicit modern Windows targets
# conhost = force the classic Windows console compatibility profile
PROMPTIFY_TERMINAL_PROFILE="auto"

# FALLBACK TERMINAL SIZE USED WHEN THE REAL TTY SIZE IS UNAVAILABLE
PROMPTIFY_UI_TERM_FALLBACK_WIDTH=64
PROMPTIFY_UI_TERM_FALLBACK_HEIGHT=16

# SPACING BETWEEN COLUMNIZED ITEMS IN MENUS
PROMPTIFY_UI_COLUMN_PADDING=4

# PROMPT-TOOLKIT APPLICATION FLAGS
PROMPTIFY_UI_FULL_SCREEN=true
PROMPTIFY_UI_MOUSE_SUPPORT=true

# ESCAPE SEQUENCE TIMEOUT
PROMPTIFY_UI_TTIMEOUTLEN=0.05

# ----------------------------------------------------------------
# INDEXING AND WATCHING
# ----------------------------------------------------------------

# auto = native observer with polling fallback
# native = fail if native observer cannot start
# polling = force polling watcher
# off = disable live filesystem watching
PROMPTIFY_INDEX_WATCH_MODE="auto"

# ----------------------------------------------------------------
# MATCHING AND COMPLETIONS
# ----------------------------------------------------------------

# NUMBER OF PARENT SEGMENTS SHOWN IN COMPLETION META TAILS
PROMPTIFY_MATCH_DISPLAY_META_TAIL_SEGMENTS=3

# MINIMUM RAPIDFUZZ SCORE TO PREFER A COMPLETION OVER THE FULL RESULT SET
PROMPTIFY_COMPLETION_FUZZY_SCORE_CUTOFF=40

# QUERY LENGTH SWITCH BETWEEN SHORT AND LONG THRESHOLDS
PROMPTIFY_MATCH_QUERY_LENGTH_SWITCH=6

PROMPTIFY_MATCH_PATH_THRESHOLD_SHORT=78
PROMPTIFY_MATCH_PATH_THRESHOLD_LONG=86
PROMPTIFY_MATCH_LEAF_THRESHOLD_SHORT=84
PROMPTIFY_MATCH_LEAF_THRESHOLD_LONG=90

# ----------------------------------------------------------------
# RESOLVER
# ----------------------------------------------------------------

# GIT ESTIMATE CACHE TTL IN SECONDS
PROMPTIFY_GIT_ESTIMATE_CACHE_TTL=5.0

# USE AN EXACT TOKENIZER FOR BACKGROUND TOKEN COUNTS.
# WHEN FALSE, PROMPTIFY FALLS BACK TO THE LEGACY HEURISTIC ESTIMATOR.
PROMPTIFY_ADVANCED_TOKENIZER=true

# ----------------------------------------------------------------
# EDITOR BEHAVIOR
# ----------------------------------------------------------------

# SHOW THE HELP MODAL IMMEDIATELY WHEN THE INTERACTIVE EDITOR OPENS
PROMPTIFY_EDITOR_SHOW_HELP_ON_START=false

# SHOW A LINE-NUMBER GUTTER ON THE LEFT SIDE OF THE EDITOR
PROMPTIFY_EDITOR_SHOW_LINE_NUMBERS=true

# WRAP LONG LINES INSIDE THE INTERACTIVE EDITOR
PROMPTIFY_EDITOR_WORD_WRAP=false

# BULK PASTE TUNING
PROMPTIFY_EDITOR_BULK_EDIT_SUSPEND_SECONDS=0.35
PROMPTIFY_EDITOR_BULK_EDIT_SIZE_THRESHOLD=2048

# SEARCH / COMPLETION / TOKEN LOOP TUNING
PROMPTIFY_EDITOR_SEARCH_HISTORY_LIMIT=8
PROMPTIFY_EDITOR_COMPLETION_MENU_MAX_HEIGHT=12
PROMPTIFY_EDITOR_COMPLETION_MENU_SCROLL_OFFSET=1
PROMPTIFY_EDITOR_TOKEN_UPDATE_INTERVAL=0.5

# HELP MODAL DIMENSIONS
PROMPTIFY_EDITOR_HELP_WIDTH_MIN=32
PROMPTIFY_EDITOR_HELP_WIDTH_MAX=192
PROMPTIFY_EDITOR_HELP_HEIGHT_MIN=8
PROMPTIFY_EDITOR_HELP_HEIGHT_MAX=64

# ERROR / ISSUE MODAL DIMENSIONS
PROMPTIFY_EDITOR_ERROR_WIDTH_MIN=16
PROMPTIFY_EDITOR_ERROR_WIDTH_MAX=96
PROMPTIFY_EDITOR_ERROR_HEIGHT_MIN=4
PROMPTIFY_EDITOR_ERROR_HEIGHT_MAX=32

# ----------------------------------------------------------------
# THEME
# STYLE VALUES USE PROMPT-TOOLKIT STYLE SYNTAX.
# EXAMPLES: "bg:#333333 #ffffff", "fg:#00ffff bold"
# ----------------------------------------------------------------

PROMPTIFY_THEME_TOPBAR="bg:#333333 #ffffff"
PROMPTIFY_THEME_TOPBAR_MODE="bg:#333333 #aee6ff bold"
PROMPTIFY_THEME_TOPBAR_TITLE="bg:#333333 #00ffff bold"
PROMPTIFY_THEME_TOPBAR_STATUS="bg:#333333 #ffd89a"
PROMPTIFY_THEME_TOPBAR_TOKENS="bg:#333333 #ffff00"
PROMPTIFY_THEME_TOOLBAR="bg:#333333 #ffffff"
PROMPTIFY_THEME_TOOLBAR_RIGHT="bg:#333333 #00ff00"

PROMPTIFY_THEME_COMPLETION_MENU="bg:#444444 #ffffff"
PROMPTIFY_THEME_COMPLETION_MENU_CURRENT="bg:#1d6f62 #f5fffb bold"
PROMPTIFY_THEME_EDITOR_FRAME_BORDER="fg:#4a4a4a"

PROMPTIFY_THEME_SEARCH_BAR="bg:#1f1f1f #ffffff"
PROMPTIFY_THEME_SEARCH_LABEL="bg:#1f1f1f #9fe9ff bold"
PROMPTIFY_THEME_SEARCH_INPUT="bg:#2d2d2d #ffffff"
PROMPTIFY_THEME_SEARCH_STATUS="bg:#1f1f1f #ffe09c"
PROMPTIFY_THEME_SEARCH_TOGGLE_ON="bg:#1f1f1f #5fd75f bold"
PROMPTIFY_THEME_SEARCH_TOGGLE_OFF="bg:#1f1f1f #ff6b6b bold"
PROMPTIFY_THEME_SEARCH_MATCH="bg:#5d4a1d #fff0cb"
PROMPTIFY_THEME_SEARCH_MATCH_ACTIVE="bg:#1f5d8e #f7fbff bold"

PROMPTIFY_THEME_CURRENT_LINE="bg:#262a31"

PROMPTIFY_THEME_ERROR_FRAME="bg:#101317"
PROMPTIFY_THEME_ERROR_FRAME_BORDER="fg:#768394"
PROMPTIFY_THEME_ERROR_FRAME_LABEL="bg:#101317 #d7e6f6 bold"
PROMPTIFY_THEME_ERROR_TEXT="bg:#171c22 #f2f5f8"

PROMPTIFY_THEME_MENTION_TAG="fg:#00ffff bold"
PROMPTIFY_THEME_MENTION_PATH="fg:#ffaa00"
PROMPTIFY_THEME_MENTION_RANGE="fg:#ff55ff"
PROMPTIFY_THEME_MENTION_DEPTH="fg:#ff55ff"
PROMPTIFY_THEME_MENTION_EXT="fg:#ffaa00"
PROMPTIFY_THEME_MENTION_GIT_CMD="fg:#00aa00"
PROMPTIFY_THEME_MENTION_CLASS="fg:#00ff00 bold"
PROMPTIFY_THEME_MENTION_FUNCTION="fg:#5555ff"
PROMPTIFY_THEME_MENTION_METHOD="fg:#55ffff"

PROMPTIFY_THEME_INVALID_SYNTAX="bg:#7c1f24 #fff3f3"
PROMPTIFY_THEME_UNRESOLVED_REFERENCE="bg:#6e4a1c #fff0d8"

PROMPTIFY_THEME_HELP_HEADER="fg:#00ff00 bold"
PROMPTIFY_THEME_HELP_KEY="fg:#ffff00"

PROMPTIFY_THEME_TRAILING_WHITESPACE="bg:#ff0000"
PROMPTIFY_THEME_EOF_NEWLINE="fg:#ff0000"
